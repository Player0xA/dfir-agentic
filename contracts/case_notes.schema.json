{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CaseNotes",
    "type": "object",
    "properties": {
        "claims": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "claim_id": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "OBSERVATION",
                            "DERIVED",
                            "HYPOTHESIS",
                            "ASSESSMENT",
                            "GAP",
                            "UNKNOWN"
                        ]
                    },
                    "statement": {
                        "type": "string"
                    },
                    "evidence_refs": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Finding IDs, Timeline event references, or file paths."
                    },
                    "confidence": {
                        "type": "string",
                        "enum": [
                            "High",
                            "Medium",
                            "Low",
                            "N/A"
                        ]
                    },
                    "impact": {
                        "type": "string",
                        "enum": [
                            "Low",
                            "Medium",
                            "High"
                        ],
                        "description": "Used specifically for GAP/LIMITATION types."
                    },
                    "validation_plan": {
                        "type": "string",
                        "description": "Next steps to confirm or refute a hypothesis."
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "Open",
                            "Supported",
                            "Confirmed",
                            "Refuted"
                        ]
                    }
                },
                "required": [
                    "claim_id",
                    "type",
                    "statement",
                    "status"
                ]
            }
        },
        "next_steps": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    },
    "required": [
        "claims",
        "next_steps"
    ]
}