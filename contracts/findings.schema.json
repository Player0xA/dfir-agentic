{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dfir-agentic.local/contracts/findings.schema.json",
  "title": "DFIR Findings Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_metadata",
    "findings",
    "requests"
  ],
  "properties": {
    "run_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "run_id",
        "timestamp_utc",
        "environment",
        "pipeline"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 8
        },
        "timestamp_utc": {
          "type": "string",
          "minLength": 10
        },
        "environment": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "hostname",
            "os",
            "timezone"
          ],
          "properties": {
            "hostname": {
              "type": "string",
              "minLength": 1
            },
            "os": {
              "type": "string",
              "minLength": 1
            },
            "timezone": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "pipeline": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    },
    "requests": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/request"
      }
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "finding_id",
        "category",
        "summary",
        "confidence",
        "severity",
        "source",
        "evidence",
        "raw_refs"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "pattern": "^F-[A-Za-z0-9._:-]{4,64}$"
        },
        "category": {
          "type": "string",
          "enum": [
            "execution",
            "persistence",
            "credential_access",
            "lateral_movement",
            "defense_evasion",
            "collection",
            "exfiltration",
            "impact",
            "discovery",
            "unknown"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 3,
          "maxLength": 280
        },
        "confidence": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            null
          ]
        },
        "severity": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "informational",
            "low",
            "medium",
            "high",
            "critical",
            null
          ]
        },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "tool",
            "rule_id",
            "rule_title"
          ],
          "properties": {
            "tool": {
              "type": "string",
              "minLength": 1
            },
            "rule_id": {
              "type": "string",
              "minLength": 1
            },
            "rule_title": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "event_refs",
            "artifacts",
            "timestamps"
          ],
          "properties": {
            "event_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "type",
                  "ref"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "file",
                      "registry",
                      "process",
                      "event",
                      "network",
                      "other"
                    ]
                  },
                  "ref": {
                    "type": "string",
                    "minLength": 1
                  },
                  "hash_sha256": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "pattern": "^[A-Fa-f0-9]{64}$"
                  }
                }
              }
            },
            "timestamps": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "first_seen",
                "last_seen"
              ],
              "properties": {
                "first_seen": {
                  "type": "string",
                  "minLength": 10
                },
                "last_seen": {
                  "type": "string",
                  "minLength": 10
                }
              }
            }
          }
        },
        "raw_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "request_id",
        "type",
        "description",
        "priority",
        "status"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^R-[A-Za-z0-9._:-]{4,64}$"
        },
        "triggered_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "collect_more_logs",
            "enrich_context",
            "run_tool",
            "correlate"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 3,
          "maxLength": 500
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "justification": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 500
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "satisfied",
            "rejected"
          ]
        }
      }
    }
  }
}
